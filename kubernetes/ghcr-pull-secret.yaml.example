# Ne pas committer les vraies credentials — copier vers ghcr-pull-secret.yaml (gitignored) ou créer via kubectl.
# Sur le cluster : kubectl create secret docker-registry ghcr-pull ...
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull
  namespace: habit
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {"auths":{"ghcr.io":{"auth":"BASE64_user_colon_token"}}}
